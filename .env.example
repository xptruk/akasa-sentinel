# ==============================================================================
# AKASA Sentinel - Environment Configuration
# ==============================================================================

# --- Core Network Settings ---
MONERO_NETWORK=mainnet
REMOTE_NODE_URLS=http://node1:18081,http://node2:18081
NODE_TIMEOUT=15

# --- Watcher Engine Settings ---
SCAN_INTERVAL=20

# --- Database & Persistence ---
# Mode: standalone (RAM only) or integrated (with SQLite)
# Note: The Active API (Cashier) feature requires 'integrated' mode.
DATABASE_MODE=standalone
# Database URL (Optional, default: sqlite://akasa_sentinel.db)
# DATABASE_URL=sqlite://my_custom_db.db

# --- Webhooks & Reliability ---
WEBHOOK_MAX_RETRIES=10
WEBHOOK_RETRY_DELAY=60

# --- Database Pruning ---
DB_PRUNING_ENABLED=true
DB_PRUNING_DAYS=30
DB_PRUNING_INTERVAL_HOURS=24

# --- Management API (Active Port) ---
MGMT_ADDR=127.0.0.1:9090
# Send the 'X-API-Key: your_secret' header when calling the API port 9090.
MGMT_API_KEY=replace_with_your_secret_key_12345

# --- Logging Settings ---
RUST_LOG=info, akasa_sentinel=debug

# --- Privacy & Proxy ---
# SOCKS5_PROXY=socks5://127.0.0.1:9050